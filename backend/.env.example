# Database
DATABASE_URL=postgresql+asyncpg://ideago:password@localhost:5432/ideago
DATABASE_URL_SYNC=postgresql://ideago:password@localhost:5432/ideago

# Auth
SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Object Storage (S3-compatible)
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=ideago
STORAGE_PRESIGN_EXPIRY_SECONDS=3600

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# App
APP_ENV=development
MAX_UPLOAD_SIZE_MB=20
CANVAS_MAX_PAYLOAD_MB=10
CANVAS_AUTO_SAVE_INTERVAL_MINUTES=5
AI_CONTEXT_MAX_EVENTS=30
AI_CONTEXT_MAX_INPUT_TOKENS=2000
AI_MAX_OUTPUT_TOKENS=2000
AI_AGENT_TIMEOUT_SECONDS=15
EXPORT_DOWNLOAD_EXPIRY_HOURS=24
AUTOTITLE_RATE_LIMIT_SECONDS=30
