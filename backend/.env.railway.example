# ─── Railway 환경변수 설정 가이드 ─────────────────────────────────────────────
# Railway 대시보드 → 서비스 선택 → Variables 탭에 아래 값들을 입력하세요.
# Railway가 자동 제공하는 변수 (직접 입력 불필요):
#   DATABASE_URL, REDIS_URL → PostgreSQL / Redis 플러그인 추가 시 자동 설정

# ─── Database ─────────────────────────────────────────────────────────────────
# Railway PostgreSQL 플러그인 추가 시 자동 주입됨
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL_SYNC=postgresql://user:password@host:5432/dbname

# ─── Auth ─────────────────────────────────────────────────────────────────────
# 랜덤 문자열 생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Object Storage ───────────────────────────────────────────────────────────
# 옵션 A: Cloudflare R2 (무료 10GB, 권장)
#   R2 대시보드 → API Tokens → Create API Token
STORAGE_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-r2-access-key-id
STORAGE_SECRET_KEY=your-r2-secret-access-key
STORAGE_BUCKET_NAME=ideago

# 옵션 B: AWS S3
#   STORAGE_ENDPOINT_URL은 비워두기 (또는 삭제)
# STORAGE_ENDPOINT_URL=
# STORAGE_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# STORAGE_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# STORAGE_BUCKET_NAME=ideago-prod

# ─── AI ───────────────────────────────────────────────────────────────────────
# Anthropic API 키: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Celery / Redis ───────────────────────────────────────────────────────────
# Railway Redis 플러그인 추가 시 자동 주입됨
CELERY_BROKER_URL=redis://default:password@host:6379/0
CELERY_RESULT_BACKEND=redis://default:password@host:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# APK(Capacitor) + 브라우저 테스트용 URL을 쉼표로 구분하여 입력
# https://localhost, capacitor://localhost → APK 필수
# https://your-frontend.railway.app → 웹 브라우저 테스트용 (있으면 추가)
CORS_ORIGINS=https://localhost,capacitor://localhost,http://localhost:3000

# ─── App settings ─────────────────────────────────────────────────────────────
APP_ENV=production
MAX_UPLOAD_SIZE_MB=20
